@headitem Command @tab Key @tab Edits
@item @code{bmkx-bmenu-edit-bookmark-name-and-location} @tab @kbd{r} @tab Name and target file (minibuffer).
@item @code{bmkx-bmenu-edit-bookmark-record}      @tab @kbd{e}   @tab Full record (Lisp sexp).
